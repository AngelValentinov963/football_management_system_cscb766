@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h1>Club Dashboard</h1>
        <p class="subtitle">Overview of your squad, fixtures and finances.</p>
    </div>
</div>

<!-- STATS -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card bg-primary">
            <div class="card-body">
                <h5>Players</h5>
                <h2>@ViewBag.TotalPlayers</h2>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card bg-dark">
            <div class="card-body">
                <h5>Teams</h5>
                <h2>@ViewBag.TotalTeams</h2>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card bg-success">
            <div class="card-body">
                <h5>Matches</h5>
                <h2>@ViewBag.TotalMatches</h2>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card bg-warning">
            <div class="card-body">
                <h5>Goals</h5>
                <h2>@ViewBag.TotalGoals</h2>
            </div>
        </div>
    </div>
</div>

<!-- NAVIGATION CARDS -->
<div class="row g-3">
    <div class="col-6 col-md-3">
        <a asp-controller="Teams" asp-action="Index" class="dashboard-card">
            <div class="card">
                <img src="/images/teams.jpg" class="card-img-top" alt="Teams" />
                <div class="card-body text-center">
                    <h3>Teams</h3>
                    <p>Manage clubs in the league.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Player" asp-action="Index" class="dashboard-card">
            <div class="card">
                <img src="/images/players.jpg" class="card-img-top" alt="Players" />
                <div class="card-body text-center">
                    <h3>Players</h3>
                    <p>Browse the full player pool.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Squad" asp-action="Index" class="dashboard-card">
            <div class="card">
                <img src="/images/matches.jpg" class="card-img-top" alt="Squad" />
                <div class="card-body text-center">
                    <h3>Squad</h3>
                    <p>Pick your starting eleven.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Market" asp-action="Index" class="dashboard-card">
            <div class="card">
                <img src="/images/market.jpg" class="card-img-top" alt="Market" />
                <div class="card-body text-center">
                    <h3>Market</h3>
                    <p>Buy and sell players.</p>
                </div>
            </div>
        </a>
    </div>
</div>

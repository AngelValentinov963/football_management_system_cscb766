@model IEnumerable<football_management_system_cscb.Models.Team>
@{ ViewData["Title"] = "Teams"; }

<div class="page-header">
    <div>
        <h1>Teams</h1>
        <p class="subtitle">All clubs registered in the league.</p>
    </div>
</div>

<div class="player-table card">
    <div class="table-responsive scroll-table">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>City</th>
                    <th>Founded</th>
                    <th>Stadium</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var team in Model)
                {
                    <tr>
                        <td class="text-muted">#@team.TeamId</td>
                        <td><strong>@team.Name</strong></td>
                        <td>@team.City</td>
                        <td>@team.FoundationYear</td>
                        <td>@team.Stadium</td>
                        <td>
                            <button class="btn btn-sm btn-primary"
                                    onclick="selectTeam(@team.TeamId)">
                                Choose
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<script>
    function selectTeam(teamId) {

        if (!confirm("Choose this team for your career?"))
            return;

        fetch('/Teams/AssignTeam?teamId=' + teamId, {
            method: 'POST'
        })
        .then(response => {
            if (response.ok) {
                window.location.href = '/Home/Index';
            }
            else {
                alert('Failed to assign team.');
            }
        });
    }
</script>
@model IEnumerable<football_management_system_cscb.ViewModels.PlayerViewModel>
@{ ViewData["Title"] = "Transfer Market"; }

<div class="page-header">
    <div>
        <h1>Transfer Market</h1>
        <p class="subtitle">Sign new talent to strengthen your squad.</p>
    </div>
</div>

<div class="player-table card">
    <div class="table-responsive scroll-table">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Player</th>
                    <th>Age</th>
                    <th>Nationality</th>
                    <th>Position</th>
                    <th>Asking Price</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <p>No players available.</p>
                }
                else
                {
                    foreach (var player in Model)
                    {
                        <tr>
                            <td><strong>@player.FullName</strong></td>
                            <td>@(DateTime.Today.Year - player.BirthDate.Year)</td>
                            <td>@player.Nationality</td>
                            <td><span class="position-badge">@player.PreferredPosition</span></td>
                            <td><strong>€@string.Format("{0:N0}", player.MarketValue ?? 0)</strong></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
